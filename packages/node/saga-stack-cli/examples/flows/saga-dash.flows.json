{
  "$comment": "EXAMPLE / AUTHORING TEMPLATE bundled with @saga-ed/saga-stack-cli (plan §5.2). This mirrors saga-dash/apps/web/dash/e2e/flows.json (authored in the saga-dash repo as a FOLLOW-UP PR). Validated by core/flow `flowManifestSchema` (zod). Used by the CLI's flow-resolver tests and as the copy-paste template for onboarding a new SPA.",
  "schemaVersion": 1,
  "spa": {
    "id": "saga-dash",
    "system": "saga-dash",
    "repoEnvVar": "SAGA_DASH",
    "defaultRepoSubpath": "saga-dash",
