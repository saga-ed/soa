{
    "name": "@saga-ed/infra-compose",
    "version": "1.1.0",
    "description": "Composable Docker service templates for Saga platform local development",
    "bin": {
        "infra-compose": "bin/infra-compose"
    },
    "scripts": {
        "lint": "eslint .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "bash test/integration/run-integration.sh",
        "typecheck": "tsc --noEmit --strict --moduleResolution node16 --module node16 --target es2022 --skipLibCheck src/api.d.ts src/handlers.d.ts",
        "prepublishOnly": "bash ../scripts/co-login.sh"
    },
    "type": "module",
    "main": "src/api.js",
    "exports": {
        ".": "./src/api.js",
        "./router": "./src/router.js",
        "./handlers": "./src/handlers.js",
        "./ec2-router": "./src/ec2/ec2-router.js",
        "./ec2-server": "./src/ec2/server.js"
    },
    "types": "src/api.d.ts",
    "files": [
        "bin/",
        "compose/",
        "src/",
        ".env.defaults"
    ],
    "dependencies": {
        "express": "^4.22.1",
        "mongodb": "^6.0.0",
        "mysql2": "^3.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.1.0",
        "typescript": "^5.9.3",
        "vitest": "^1.6.1"
    },
    "publishConfig": {
        "registry": "https://saga-531314149529.d.codeartifact.us-west-2.amazonaws.com/npm/saga_js/",
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/hipponot/saga-soa.git",
        "directory": "infra"
    }
}
