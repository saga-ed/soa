{
  "extends": "@saga-ed/soa-typescript-config/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/__tests__/**",
    "src/**/*.unit.test.ts",
    "src/**/*.int.test.ts",
    "vitest.config.ts"
  ]
}
